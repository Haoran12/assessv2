ASSESS_SERVER_HOST=127.0.0.1
ASSESS_SERVER_PORT=8080
ASSESS_SQLITE_PATH=./data/assess.db
ASSESS_SQLITE_FOREIGN_KEYS=true
ASSESS_SQLITE_JOURNAL_MODE=WAL
ASSESS_SQLITE_SYNCHRONOUS=NORMAL
ASSESS_SQLITE_BUSY_TIMEOUT_MS=5000
ASSESS_SQLITE_CACHE_SIZE=-20000
ASSESS_SQLITE_TEMP_STORE=MEMORY
ASSESS_SQLITE_MAX_OPEN_CONNS=1
ASSESS_SQLITE_MAX_IDLE_CONNS=1
ASSESS_SQLITE_CONN_MAX_LIFETIME_SECONDS=0
ASSESS_JWT_SECRET=replace-with-production-secret
ASSESS_DEFAULT_PASSWORD=#2026@hdwl
ASSESS_ENFORCE_MUST_CHANGE_PASSWORD=false
